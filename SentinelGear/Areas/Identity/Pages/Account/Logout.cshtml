@page
@model LogoutModel
@{
    ViewData["Title"] = "Изход";
}

<section class="hero-section text-center">
    <div class="row justify-content-center">
        <div class="col-lg-6">

            <div class="info-card p-5 text-center">
                <div class="icon-box mx-auto mb-4">
                    <i class="bi bi-check-circle-fill"></i>
                </div>

                <h2 class="mb-3">Успешно излязохте</h2>

                <p class="text-muted-tactical mb-4">
                    Ще бъдете пренасочени към началната страница след няколко секунди.
                </p>

                <a asp-area="" asp-controller="Home" asp-action="Index" class="btn btn-outline-tactical">
                    Към началната страница
                </a>
            </div>

        </div>
    </div>
</section>

<script>
    setTimeout(function () {
        window.location.href = '/';
    }, 2500);
</script>