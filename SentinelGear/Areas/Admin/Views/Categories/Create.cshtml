@model SentinelGear.ViewModels.CategoryFormViewModel

@{
    ViewData["Title"] = "Добавяне на категория";
}

<div class="container mt-4">
    <div class="card bg-dark text-light shadow-sm p-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="mb-0">Добавяне на категория</h1>
            <a asp-area="Admin" asp-controller="Categories" asp-action="Index" class="btn btn-secondary">
                Към списъка
            </a>
        </div>

        <form asp-area="Admin" asp-controller="Categories" asp-action="Create" method="post">
            <div class="mb-3">
                <label asp-for="Name" class="form-label text-light"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Добавете категория</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}