@model IEnumerable<SentinelGear.Models.Category>

@{
    ViewData["Title"] = "Админ - Категории";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-light">Управление на категории</h1>
        <a asp-area="Admin" asp-controller="Categories" asp-action="Create" class="btn btn-success">
            + Добави категория
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card bg-dark text-light shadow-sm p-3">
        @if (!Model.Any())
        {
            <p class="mb-0">Няма добавени категории.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-dark table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Име</th>
                            <th>Брой продукти</th>
                            <th class="text-end">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (Category category in Model)
                        {
                            <tr>
                                <td>@category.Id</td>
                                <td>@category.Name</td>
                                <td>@category.Products.Count(p => !p.IsDeleted)</td>
                                <td class="text-end">
                                    <a asp-area="Admin" asp-controller="Categories" asp-action="Edit"
                                        asp-route-id="@category.Id" class="btn btn-warning btn-sm">
                                        Редактирай
                                    </a>
                                    <a asp-area="Admin" asp-controller="Categories" asp-action="Delete"
                                        asp-route-id="@category.Id" class="btn btn-danger btn-sm">
                                        Изтрий
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>