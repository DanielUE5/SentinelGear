@model SentinelGear.Models.Product

@{
    ViewData["Title"] = "Изтриване на продукт";
}

<div class="container mt-4">
    <div class="card bg-dark text-light shadow-sm p-4">
        <h1 class="mb-4 text-danger">Изтриване на продукт</h1>

        <div class="row g-4 align-items-start">
            <div class="col-md-4">
                <img src="@(string.IsNullOrWhiteSpace(Model.ImageUrl) ? "/images/image_not_found.jpg" : Model.ImageUrl)"
                    alt="@Model.Name" class="img-fluid rounded" />
            </div>

            <div class="col-md-8">
                <h3>@Model.Name</h3>
                <p><strong>Категория:</strong> @Model.Category?.Name</p>
                <p><strong>Цена:</strong> @Model.Price.ToString("F2") лв.</p>
                <p><strong>Наличност:</strong> @Model.StockQuantity</p>
                <p><strong>Производител:</strong> @(string.IsNullOrWhiteSpace(Model.Manufacturer) ? "-" :
                                        Model.Manufacturer)</p>
                <p><strong>Описание:</strong> @Model.Description</p>

                <div class="alert alert-warning mt-3">
                    Сигурни ли сте, че искате да изтриете този продукт?
                </div>

                <form asp-area="Admin" asp-controller="Products" asp-action="DeleteConfirmed" asp-route-id="@Model.Id"
                    method="post">
                    <button type="submit" class="btn btn-danger">Да, изтрий</button>
                    <a asp-area="Admin" asp-controller="Products" asp-action="Index" class="btn btn-secondary">Отказ</a>
                </form>
            </div>
        </div>
    </div>
</div>