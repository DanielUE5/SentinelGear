@model IEnumerable<SentinelGear.Models.Product>

@{
    ViewData["Title"] = "Админ - Продукти";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-light">Управление на продукти</h1>
        <a asp-area="Admin" asp-controller="Products" asp-action="Create" class="btn btn-success">
            + Добави продукт
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card bg-dark text-light shadow-sm p-3">
        @if (!Model.Any())
        {
            <p class="mb-0">Няма добавени продукти.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-dark table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Снимка</th>
                            <th>Име</th>
                            <th>Категория</th>
                            <th>Цена</th>
                            <th>Наличност</th>
                            <th>Производител</th>
                            <th>Статус</th>
                            <th class="text-end">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (Product product in Model)
                        {
                            <tr>
                                <td>@product.Id</td>
                                <td>
                                    <img src="@(string.IsNullOrWhiteSpace(product.ImageUrl) ? "/images/image_not_found.jpg" : product.ImageUrl)"
                                        alt="@product.Name"
                                        style="width: 70px; height: 70px; object-fit: cover; border-radius: 8px;" />
                                </td>
                                <td>@product.Name</td>
                                <td>@product.Category?.Name</td>
                                <td>@product.Price.ToString("F2") лв.</td>
                                <td>@product.StockQuantity</td>
                                <td>@(string.IsNullOrWhiteSpace(product.Manufacturer) ? "-" : product.Manufacturer)</td>
                                <td>
                                    @if (product.IsDeleted)
                                    {
                                        <span class="badge bg-danger">Изтрит</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">Активен</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <a asp-area="Admin" asp-controller="Products" asp-action="Edit" asp-route-id="@product.Id"
                                        class="btn btn-warning btn-sm">
                                        Редактирай
                                    </a>
                                    <a asp-area="Admin" asp-controller="Products" asp-action="Delete" asp-route-id="@product.Id"
                                        class="btn btn-danger btn-sm">
                                        Изтрий
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>