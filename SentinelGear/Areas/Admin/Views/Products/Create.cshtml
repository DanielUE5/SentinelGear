@model SentinelGear.ViewModels.ProductFormViewModel

@{
    ViewData["Title"] = "Добавяне на продукт";
}

<div class="container mt-4">
    <div class="card bg-dark text-light shadow-sm p-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="mb-0">Добавяне на продукт</h1>
            <a asp-area="Admin" asp-controller="Products" asp-action="Index" class="btn btn-secondary">
                Към списъка
            </a>
        </div>

        <form asp-area="Admin" asp-controller="Products" asp-action="Create" method="post"
            enctype="multipart/form-data">
            <div class="mb-3">
                <label asp-for="Name" class="form-label text-light"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label text-light"></label>
                <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Price" class="form-label text-light"></label>
                <input asp-for="Price" class="form-control" />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="StockQuantity" class="form-label text-light"></label>
                <input asp-for="StockQuantity" class="form-control" />
                <span asp-validation-for="StockQuantity" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Manufacturer" class="form-label text-light"></label>
                <input asp-for="Manufacturer" class="form-control" />
                <span asp-validation-for="Manufacturer" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="CategoryId" class="form-label text-light"></label>
                <select asp-for="CategoryId" asp-items="Model.Categories" class="form-select">
                    <option value="">Изберете категория</option>
                </select>
                <span asp-validation-for="CategoryId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ImageFile" class="form-label text-light"></label>
                <input asp-for="ImageFile" type="file" class="form-control" accept=".jpg,.jpeg,.png,.webp" />
                <span asp-validation-for="ImageFile" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Добави продукт</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}