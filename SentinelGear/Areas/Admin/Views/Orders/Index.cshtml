@model IEnumerable<SentinelGear.Models.Order>
@using SentinelGear.Models.Enums

@{
    ViewData["Title"] = "Админ - Поръчки";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="text-light">Управление на поръчки</h1>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card bg-dark text-light shadow-sm p-3">
        @if (!Model.Any())
        {
            <p class="mb-0">Все още няма направени поръчки.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-dark table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Клиент</th>
                            <th>Телефон</th>
                            <th>Адрес</th>
                            <th>Дата</th>
                            <th>Продукти</th>
                            <th>Обща сума</th>
                            <th>Статус</th>
                            <th class="text-end">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (Order order in Model)
                        {
                            <tr>
                                <td>#@order.Id</td>
                                <td>@order.FirstName @order.LastName</td>
                                <td>@order.PhoneNumber</td>
                                <td>@order.Address</td>
                                <td>@order.CreatedOn.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                                <td>@order.OrderItems.Sum(oi => oi.Quantity)</td>
                                <td>@order.TotalAmount.ToString("F2") лв.</td>
                                <td>
                                    @switch (order.Status)
                                    {
                                        case OrderStatus.Pending:
                                            <span class="badge bg-warning text-dark">Изчаква</span>
                                            break;
                                        case OrderStatus.Processing:
                                            <span class="badge bg-info text-dark">Обработва се</span>
                                            break;
                                        case OrderStatus.Delivered:
                                            <span class="badge bg-success">Доставена</span>
                                            break;
                                        case OrderStatus.Cancelled:
                                            <span class="badge bg-danger">Отказана</span>
                                            break;
                                    }
                                </td>
                                <td class="text-end">
                                    <a asp-area="Admin" asp-controller="Orders" asp-action="Details" asp-route-id="@order.Id"
                                        class="btn btn-primary btn-sm">
                                        Детайли
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>