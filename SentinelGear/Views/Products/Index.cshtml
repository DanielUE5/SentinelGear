@using SentinelGear.Helpers
@model ProductCatalogViewModel

@{
    ViewData["Title"] = "Продукти";
}

<h1 class="section-title">Продукти</h1>

<div id="cart-toast" class="cart-toast">
    <i class="bi bi-check-circle-fill"></i>
    <span id="cart-toast-message">Продуктът е добавен в количката.</span>
</div>

<div class="filter-box mb-4">
    <form method="get" asp-action="Index" class="row g-3 mb-4">
        <div class="col-md-4">
            <input asp-for="Filter.SearchTerm" class="form-control"
                placeholder="Търсене по име, описание или производител" />
        </div>

        <div class="col-md-2">
            <select asp-for="Filter.CategoryId" asp-items="Model.Categories" class="form-select">
                <option value="">Всички категории</option>
            </select>
        </div>

        <div class="col-md-2">
            <select asp-for="Filter.Manufacturer" asp-items="Model.Manufacturers" class="form-select">
                <option value="">Всички производители</option>
            </select>
        </div>

        <div class="col-md-2">
            <input asp-for="Filter.MinPrice" class="form-control" placeholder="Мин. цена (€)" />
        </div>

        <div class="col-md-2">
            <input asp-for="Filter.MaxPrice" class="form-control" placeholder="Макс. цена (€)" />
        </div>

        <div class="col-12">
            <button type="submit" class="btn btn-primary">Филтрирай</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Изчисти</a>
        </div>
    </form>
</div>

@if (!Model.Products.Any())
{
    <div class="alert alert-warning">
        Няма намерени продукти.
    </div>
}
else
{
    <div class="product-grid">
        @foreach (Product product in Model.Products)
        {
            <div class="product-card">
                <img src="@(string.IsNullOrWhiteSpace(product.ImageUrl) ? "/images/image_not_found.jpg" : product.ImageUrl)"
                    alt="@product.Name" loading="lazy" onerror="this.src='/images/image_not_found.jpg'" />

                <div class="product-info">
                    <div class="product-title">@product.Name</div>
                    <div class="product-description">@product.Description</div>

                    <div class="product-price">
                        €@CurrencyConverter.ConvertBgnToEur(product.Price)
                        <span class="text-muted small">
                            (@product.Price.ToString("F2") лв.)
                        </span>
                    </div>

                    <div class="product-stock">
                        Наличност: @product.StockQuantity
                    </div>

                    <div class="d-grid gap-2">

                        <a asp-controller="Products" asp-action="Details" asp-route-id="@product.Id" class="btn btn-tactical">
                            Виж детайли
                        </a>
                        @Html.AntiForgeryToken()
                        <button class="btn btn-tactical w-100 add-to-cart-btn" data-product-id="@product.Id"
                            data-product-name="@product.Name">
                            <i class="bi bi-cart3"></i> Добави в количка
                        </button>

                    </div>
                </div>
            </div>
        }
    </div>
}
<script src="~/js/cart.js"></script>