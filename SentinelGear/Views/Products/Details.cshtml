@using SentinelGear.Helpers
@model SentinelGear.Models.Product

@{
    ViewData["Title"] = "Детайли за продукт";
}

<h1 class="section-title">Детайли за продукта</h1>

<div class="row g-4">
    <div class="col-md-6">
        <div class="product-card">
            <img src="@(string.IsNullOrWhiteSpace(Model.ImageUrl) ? "/images/image_not_found.jpg" : Model.ImageUrl)" alt="@Model.Name" />
        </div>
    </div>

    <div class="col-md-6">
        <div class="info-card p-4 h-100">
            <h2 class="mb-3">@Model.Name</h2>
            <p class="text-muted-tactical">@Model.Description</p>

            <p><strong>Категория:</strong> @Model.Category?.Name</p>
            <p><strong>Производител:</strong> @(string.IsNullOrWhiteSpace(Model.Manufacturer) ? "Няма информация" : Model.Manufacturer)</p>
            <p><strong>Наличност:</strong> @Model.StockQuantity</p>
            <div class="product-price">
                €@CurrencyConverter.ConvertBgnToEur(Model.Price)
                <span class="text-muted small">
                    (@Model.Price.ToString("F2") лв.)
                </span>
            </div>

            <div class="d-flex gap-3 mt-4">
                <a asp-controller="Products" asp-action="Index" class="btn btn-outline-tactical">Назад</a>
                <a href="#" class="btn btn-tactical disabled">Добави в количка</a>
            </div>
        </div>
    </div>
</div>