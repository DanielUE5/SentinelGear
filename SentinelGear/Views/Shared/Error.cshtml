@using SentinelGear.ViewModels
@model ErrorViewModel
@{
    ViewData["Title"] = "Грешка";
}

<h1 class="text-danger">Грешка.</h1>
<h2 class="text-danger">Възникна грешка при обработката на вашето запитване.</h2>

@if (Model.ShowRequestId)
{
    <p>
        <strong>ID на заявката:</strong> <code>@Model.RequestId</code>
    </p>
}

<h3>Режим за разработка (Development)</h3>
<p>
    При активиране на режим <strong>Development</strong> ще се показва по-подробна информация за възникналата грешка.
</p>
<p>
    <strong>Режимът Development не трябва да бъде използван в реална (production) среда.</strong>
    Той може да доведе до показване на чувствителна информация за грешките към потребителите.
    За локално тестване активирайте <strong>Development</strong> чрез задаване на променливата
    <strong>ASPNETCORE_ENVIRONMENT</strong> със стойност <strong>Development</strong>
    и рестартирайте приложението.
</p>