@using SentinelGear.Extensions
@using SentinelGear.ViewModels

@{
    IEnumerable<CartItemViewModel> cartItems = Context.Session.GetObject<List<CartItemViewModel>>("ShoppingCart")
    ?? new List<CartItemViewModel>();

    int cartItemsCount = cartItems.Sum(item => item.Quantity);
    bool isAuthenticated = User.Identity?.IsAuthenticated == true;
    bool isAdmin = User.IsInRole("Admin");
}

<!DOCTYPE html>
<html lang="bg">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SentinelGear</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/sentinel-gear.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-lg">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">SentinelGear</a>

                @if (isAdmin)
                {
                    <span class="badge bg-danger ms-3 text-uppercase">Admin Panel</span>
                }

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
                    aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        @if (!isAdmin)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Начало</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Products" asp-action="Index">Продукти</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Categories" asp-action="Index">Категории</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Home" asp-action="About">За нас</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Contacts">Контакти</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="Admin" asp-controller="Products" asp-action="Index">
                                    Управление на продукти
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="Admin" asp-controller="Categories" asp-action="Index">
                                    Управление на категории
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="Admin" asp-controller="Orders" asp-action="Index">
                                    Управление на поръчки
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Contacts">Контакти</a>
                            </li>
                        }
                    </ul>

                    <div class="d-flex align-items-center gap-2">
                        @if (!isAdmin)
                        {
                            <a class="cart-cta-btn" asp-area="" asp-controller="Cart" asp-action="Index">
                                <i class="bi bi-cart3"></i>
                                <span>Количка</span>
                                <span class="cart-badge @(cartItemsCount == 0 ? "d-none" : "")">
                                    @cartItemsCount
                                </span>
                            </a>
                        }

                        @if (isAuthenticated)
                        {
                            <div class="dropdown">
                                <a class="nav-link dropdown-toggle text-decoration-none" href="#" role="button"
                                    data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-person-circle me-1"></i>
                                    @(isAdmin ? "Админ профил" : "Моят профил")
                                </a>

                                <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end">
                                    @if (!isAdmin)
                                    {
                                        <li>
                                            <a class="dropdown-item" asp-area="" asp-controller="Orders" asp-action="MyOrders">
                                                <i class="bi bi-bag-check me-2"></i> Моите поръчки
                                            </a>
                                        </li>
                                        <li>
                                            <hr class="dropdown-divider" />
                                        </li>
                                    }

                                    <li>
                                        <form asp-area="Identity" asp-page="/Account/Logout" method="post" class="m-0">
                                            <button type="submit" class="dropdown-item">
                                                <i class="bi bi-box-arrow-right me-2"></i> Изход
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <partial name="_LoginPartial" />
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="py-4">
            @RenderBody()
        </main>
    </div>

    <footer class="footer mt-auto py-3">
        <div class="container text-center">
            &copy; 2026 SentinelGear | Tactical Gear Store
        </div>
    </footer>

    <div id="cart-toast" class="cart-toast">
        <i class="bi bi-check-circle-fill"></i>
        <span id="cart-toast-message">Продуктът беше добавен в количката.</span>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/cart.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>